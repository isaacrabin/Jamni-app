    "jsonwebtoken": "^9.0.3",
    "nodemon": "^3.1.14",
    "prettier": "^3.7.4",
    "ts-node": "^10.9.2",
    "turbo": "^2.9.14",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
